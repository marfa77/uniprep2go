{
  "framework": "nextjs",
  "buildCommand": "npm run build && npm run indexnow:deploy",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "uniprep2go.study"
        }
      ],
      "destination": "https://www.uniprep2go.study/:path*",
      "statusCode": 301
    }
  ],
  "crons": [
    {
      "path": "/api/cron/indexnow",
      "schedule": "15 13 * * 1"
    }
  ]
}
