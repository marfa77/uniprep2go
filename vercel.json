{
  "framework": "nextjs",
  "buildCommand": "npm run build && npm run indexnow:deploy",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.uniprep2go.study"
        }
      ],
      "destination": "https://uniprep2go.study/:path*",
      "permanent": true
    },
    {
      "source": "/best-frm-part-1-anki-deck",
      "destination": "/decks/frm-part-1-anki-deck",
      "permanent": true
    },
    {
      "source": "/ciple-a2-anki-deck-for-portuguese-citizenship",
      "destination": "/decks/ciple-a2-european-portuguese-anki-deck",
      "permanent": true
    },
    {
      "source": "/anki-decks-for-language-exams",
      "destination": "/",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/indexnow",
      "schedule": "15 13 * * 1"
    }
  ]
}
