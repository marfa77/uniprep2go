{
  "name": "uniprep2go",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run check:boilerplate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "check:boilerplate": "node scripts/check-boilerplate.mjs",
    "build:mock-banks": "python3 scripts/build-mock-banks.py",
    "generate:mock-banks": "node scripts/generate-mock-banks-openrouter.mjs",
    "merge:local-banks": "node scripts/merge-local-mock-questions.mjs",
    "validate:mock-banks": "node scripts/validate-mock-banks-openrouter.mjs",
    "generate:deck-covers": "node scripts/generate-deck-covers.mjs --catalog --force",
    "generate:deck-covers:missing": "node scripts/generate-deck-covers.mjs --all-missing",
    "generate:mock-cluster-images": "tsx scripts/generate-mock-cluster-images.ts",
    "setup:gumroad-building-decks": "node scripts/setup-gumroad-building-decks.mjs",
    "scaffold:certification": "node scripts/scaffold-certification.mjs",
    "validate:certification": "node scripts/validate-certification-pipeline.mjs",
    "indexnow:deploy": "tsx src/lib/run-indexnow-deploy.ts",
    "indexnow:submit": "node scripts/indexnow.js --sitemap",
    "audit:seo": "npx tsx scripts/seo-audit-openrouter.mjs --scope all --live",
    "audit:seo:rules": "npx tsx scripts/seo-audit-openrouter.mjs --scope all --rules-only",
    "audit:seo:local": "npx tsx scripts/seo-audit-openrouter.mjs --scope all --live --rules-only",
    "audit:seo:building:local": "npx tsx scripts/seo-audit-openrouter.mjs --scope building --live --rules-only",
    "audit:seo:gmat": "npx tsx scripts/seo-audit-openrouter.mjs --scope gmat --live",
    "audit:seo:building": "npx tsx scripts/seo-audit-openrouter.mjs --scope building --live",
    "audit:visibility": "npx tsx scripts/visibility-audit-openrouter.mjs --scope all --live",
    "audit:visibility:rules": "npx tsx scripts/visibility-audit-openrouter.mjs --scope all --rules-only",
    "audit:aeo": "npx tsx scripts/aeo-audit-local.mjs --scope all",
    "audit:aeo:live": "npx tsx scripts/aeo-audit-local.mjs --scope all --live",
    "setup:gumroad-language-decks": "node scripts/setup-gumroad-language-decks.mjs",
    "publish:gumroad-language-landings": "python3 scripts/publish-language-gumroad-landings.py"
  },
  "dependencies": {
    "@upstash/redis": "^1.38.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "sharp": "^0.35.3",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
